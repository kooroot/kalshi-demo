{
  "name": "kalshi-hackathon",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch backend/src/index.ts",
    "dev:frontend": "cd frontend && bun run dev",
    "dev:all": "concurrently \"bun run dev\" \"bun run dev:frontend\"",
    "build:frontend": "cd frontend && bun run build"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/node": "^25.2.0",
    "@types/uuid": "^11.0.0",
    "concurrently": "^9.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "better-sqlite3": "^12.6.2",
    "hono": "^4.11.7",
    "uuid": "^13.0.0"
  }
}
